# DWMB: copy to .env and fill in. Keys can also be loaded from ../Inquiry.Institute/.env.local

# Supabase (optional – for storing instances, runs, and metrics)
# From Supabase Dashboard > Settings > API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Or use the same names as Inquiry.Institute
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google / Vertex AI (optional – for LLM baseline agent)
# VERTEX_PROJECT_ID=your-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
